{"type":"item.started","item":{"id":"item_70","type":"command_execution","command":"/bin/bash -lc \"pwd && mkdir -p datasets/r2r_navigation/raw datasets/r2r_navigation/samples && while IFS='|' read -r url out; do curl -L --fail --retry 3 --retry-delay 2 \\\"\"'${url}?dl=1\" -o \"datasets/r2r_navigation/raw/${out}\"; done <<'\"'EOF'\nhttps://www.dropbox.com/s/hh5qec8o5urcztn/R2R_train.json|R2R_train.json\nhttps://www.dropbox.com/s/8ye4gqce7v8yzdm/R2R_val_seen.json|R2R_val_seen.json\nhttps://www.dropbox.com/s/p6hlckr70a07wka/R2R_val_unseen.json|R2R_val_unseen.json\nhttps://www.dropbox.com/s/w4pnbwqamwzdwd1/R2R_test.json|R2R_test.json\nEOF\n. .venv/bin/activate && python - <<'PY'\nimport json\nfrom pathlib import Path\nbase = Path('datasets/r2r_navigation/raw')\nsummary = {}\nsamples = []\nfor path in sorted(base.glob('R2R_*.json')):\n    data = json.loads(path.read_text())\n    instr_count = sum(len(x.get('instructions', [])) for x in data)\n    summary[path.name] = {'paths': len(data), 'instructions': instr_count}\n    for item in data[:2]:\n        samples.append({\n            'split': path.stem.replace('R2R_', ''),\n            'path_id': item.get('path_id'),\n            'scan': item.get('scan'),\n            'path_length_nodes': len(item.get('path', [])),\n            'instructions': item.get('instructions', [])[:2],\n        })\nPath('datasets/r2r_navigation/samples/r2r_samples.json').write_text(json.dumps(samples[:8], indent=2))\nPath('datasets/r2r_navigation/summary.json').write_text(json.dumps(summary, indent=2))\nprint(json.dumps(summary, indent=2))\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
