{"type":"item.started","item":{"id":"item_77","type":"command_execution","command":"/bin/bash -lc \"pwd && . .venv/bin/activate && HF_HOME=datasets/.cache/huggingface python - <<'PY'\nfrom datasets import load_dataset\nfrom pathlib import Path\nimport json\n\nroot = Path('datasets')\n\ndef save_sample(ds, out_path, n=8):\n    out_path.parent.mkdir(parents=True, exist_ok=True)\n    rows = []\n    split = ds['train'] if isinstance(ds, dict) and 'train' in ds else ds\n    for i, row in enumerate(split):\n        if i >= n:\n            break\n        rows.append({k: row[k] for k in list(row)[:8]})\n    out_path.write_text(json.dumps(rows, indent=2, default=str))\n\n# Human/AI paired writing corpus for feature baselines.\ntry:\n    hap = load_dataset('browndw/human-ai-parallel-corpus')\n    hap_name = 'browndw/human-ai-parallel-corpus'\nexcept Exception as exc:\n    print('Full HAP failed, falling back to mini:', repr(exc))\n    hap = load_dataset('browndw/human-ai-parallel-corpus-mini')\n    hap_name = 'browndw/human-ai-parallel-corpus-mini'\nhap_dir = root / 'human_ai_parallel_corpus'\nhap.save_to_disk(str(hap_dir))\nsave_sample(hap, hap_dir / 'samples' / 'sample.json', n=6)\nprint('saved', hap_name, hap)\n\n# Controlled spatial story-like QA: positional reasoning and path finding.\nfor config, out_name in [\n    ('task_17-positional_reasoning', 'babi_positional_reasoning'),\n    ('task_19-path_finding', 'babi_path_finding'),\n]:\n    ds = load_dataset('RawthiL/babi_tasks', config)\n    out_dir = root / out_name\n    ds.save_to_disk(str(out_dir))\n    save_sample(ds, out_dir / 'samples' / 'sample.json', n=8)\n    print('saved', config, ds)\n\n# Human-written fiction sample filtered for spatial-navigation vocabulary.\nkeywords = {\n    'room','door','hall','hallway','corridor','stairs','staircase','building','apartment',\n    'house','kitchen','bedroom','bathroom','floor','walked','walk','entered','entrance',\n    'turned','turn','left','right','upstairs','downstairs','inside','outside'\n}\nwp_dir = root / 'writingprompts_spatial_sample'\n(wp_dir / 'samples').mkdir(parents=True, exist_ok=True)\nstream = load_dataset('euclaise/writingprompts', split='train', streaming=True)\nrows = []\nseen = 0\nfor row in stream:\n    seen += 1\n    text = ' '.join(str(row.get(k,'')) for k in row.keys()).lower()\n    if any(kw in text for kw in keywords):\n        rows.append(row)\n    if len(rows) >= 500 or seen >= 25000:\n        break\nwith (wp_dir / 'samples' / 'spatial_filtered_500.jsonl').open('w') as f:\n    for row in rows:\n        f.write(json.dumps(row, ensure_ascii=False) + '\\\\n')\nsummary = {'source': 'euclaise/writingprompts', 'streamed_train_rows_seen': seen, 'spatial_keyword_matches_saved': len(rows), 'keywords': sorted(keywords)}\n(wp_dir / 'summary.json').write_text(json.dumps(summary, indent=2))\nprint('saved writingprompts sample', summary)\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
